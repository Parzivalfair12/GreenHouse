# =============================================================================
# GreenHouse — Variables de entorno para ejecucion local
# Copiar este archivo a .env y completar los valores reales.
# NUNCA subir .env real a Git (ya esta en .gitignore).
# =============================================================================

# --- Base de datos (Neon PostgreSQL) ---
# OBTEN TU URL EN: https://console.neon.tech -> Connection Details -> JDBC
# Ejemplo: jdbc:postgresql://ep-tu-proyecto-xxxxx-pooler.sa-east-1.aws.neon.tech:5432/neondb?sslmode=require&channel_binding=require
DB_URL=__REEMPLAZA_AQUI_TU_URL_JDBC_DE_NEON__
DB_USERNAME=__REEMPLAZA_AQUI_TU_USERNAME_DE_NEON__
DB_PASSWORD=__REEMPLAZA_AQUI_TU_PASSWORD_DE_NEON__

# --- Perfil activo de Spring (siempre "local" para desarrollo con Neon) ---
SPRING_PROFILES_ACTIVE=local

# --- JWT (minimo 32 caracteres) ---
JWT_SECRET=change-me-in-production-min-32-chars-long-secret

# --- Frontend ---
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8080

# --- IA (Flask - opcional, desactivado si no responde) ---
IA_URL=http://localhost:5000

# --- OAuth2 Google (opcional - desactivado por defecto) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_ENABLED=false
OAUTH2_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
OAUTH2_ADMIN_EMAILS=

# --- Taiga (opcional - desactivado si no hay token) ---
TAIGA_API_URL=https://api.taiga.io/api/v1
TAIGA_TOKEN=
TAIGA_PROJECT_ID=

# --- GitHub Actions (opcional) ---
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# --- Email / SMTP (opcional) ---
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Admin seed ---
ADMIN_PASSWORD=admin1234
SEEDER_ENABLED=true

# --- Hikari ---
HIKARI_MAX_POOL=10
HIKARI_MIN_IDLE=2

# --- Logging ---
LOG_LEVEL_ROOT=INFO
LOG_SQL=WARN
LOG_BIND=WARN

# --- Swagger (siempre activo en local) ---
SWAGGER_ENABLED=true

# --- Frontend OAuth flag (debe coincidir con OAUTH2_ENABLED) ---
VITE_OAUTH_ENABLED=false
VITE_API_URL=
