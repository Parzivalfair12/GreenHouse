# =============================================================================
# GreenHouse — Docker Compose environment variables
# Copy this file to .env and adjust for your environment
# =============================================================================

# PostgreSQL
DB_PASSWORD=greenhouse_pass

# JWT (64+ chars recommended for production)
JWT_SECRET=dev-only-change-me-in-production-0123456789abcdef0123456789abcdef

# Frontend URL (CORS + OAuth redirect)
FRONTEND_URL=http://localhost:5173

# Google OAuth2 (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_ENABLED=false

# Admin seed password
ADMIN_PASSWORD=admin_dev_change_me

# Email (disabled by default)
EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
