# =============================================================================
# GreenHouse — Environment variables template
# Copy to .env and fill in your real values.
# =============================================================================

# Database
DB_PASSWORD=change_me_in_production

# JWT (must be at least 32 characters)
JWT_SECRET=change-me-in-production-min-32-chars-long-secret

# Frontend URL (used for CORS and email links)
FRONTEND_URL=http://localhost:5173

# OAuth2 Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_ENABLED=false
# Optional: override redirect URI (default: auto-derived from request)
OAUTH2_REDIRECT_URI=
# Comma-separated list of emails that should get ADMIN role via OAuth
OAUTH2_ADMIN_EMAILS=

# Admin seed password
ADMIN_PASSWORD=change_me_in_production

# Email / SMTP
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_AUTH=true
SMTP_TLS=true

# IA service URL (Docker internal)
IA_URL=http://greenhouse-ia:5000

# Frontend build
VITE_API_URL=

# Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev
