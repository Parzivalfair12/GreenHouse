# Database (local dev defaults match standard PostgreSQL installation)
DB_URL=jdbc:postgresql://localhost:5432/greenhouse
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT (REQUIRED for production; generate with: openssl rand -base64 48)
JWT_SECRET=dev-only-change-me-in-production-0123456789abcdef0123456789abcdef

# Frontend URL (CORS and OAuth redirect)
FRONTEND_URL=http://localhost:5173

# Google OAuth2 (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_ENABLED=false
# Optional: override redirect URI (default: auto-derived from request)
# For production behind a reverse proxy, set to: https://yourdomain.com/login/oauth2/code/google
OAUTH2_REDIRECT_URI=
# Comma-separated OAuth emails that get ADMIN role (others get OPERATOR)
OAUTH2_ADMIN_EMAILS=

# Admin seed password (change in production)
ADMIN_PASSWORD=admin_dev_change_me

# Email / SMTP (disabled by default; set EMAIL_ENABLED=true for real SMTP)
EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_AUTH=false
SMTP_TLS=false
