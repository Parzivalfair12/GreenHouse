<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- JSON appender para logs estructurados enterprise -->
  <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <includeMdcKeyName>correlationId</includeMdcKeyName>
      <includeMdcKeyName>userId</includeMdcKeyName>
      <includeMdcKeyName>endpoint</includeMdcKeyName>
      <includeContext>false</includeContext>
      <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
      <fieldNames>
        <timestamp>timestamp</timestamp>
        <level>level</level>
        <logger>logger</logger>
        <message>message</message>
        <thread>thread</thread>
      </fieldNames>
    </encoder>
  </appender>

  <!-- Plain text appender para desarrollo local -->
  <appender name="PLAIN" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%-16X{correlationId}] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Perfil dev: plain text legible -->
  <springProfile name="dev">
    <root level="INFO">
      <appender-ref ref="PLAIN"/>
    </root>
    <logger name="com.example.greenhouse" level="DEBUG"/>
  </springProfile>

  <!-- Perfil prod/test: JSON estructurado -->
  <springProfile name="!dev">
    <root level="INFO">
      <appender-ref ref="JSON"/>
    </root>
    <logger name="com.example.greenhouse" level="INFO"/>
  </springProfile>
</configuration>
